# Gemini CLI agent image. Extends the ProPR agent base image (alpine + common tooling).
# The CLI is installed at build time and exercised with --version as a smoke
# test so binary-loading regressions fail the build rather than leaking into
# user runtime.
#
# Note: agent-base includes GNU coreutils, which is required for Gemini's
# `#!/usr/bin/env -S node` shebang (BusyBox env doesn't support -S).

# BASE_IMAGE must point at the exact agent-base image built alongside this
# agent image. scripts/build-images.sh passes it automatically.
ARG BASE_IMAGE=propr/agent-base:latest
FROM ${BASE_IMAGE}

ARG CLI_VERSION=latest

USER root
RUN npm install -g @google/gemini-cli@${CLI_VERSION}
RUN gemini --version
USER node

RUN git config --global user.name "ProPR Gemini Bot" \
    && git config --global user.email "gemini-bot@propr.dev" \
    && git config --global init.defaultBranch main \
    && git config --global --add safe.directory '*'

COPY --chown=node:node scripts/gemini-entrypoint.sh /home/node/gemini-entrypoint.sh
USER root
RUN chmod +x /home/node/gemini-entrypoint.sh
USER node

ENTRYPOINT ["/home/node/gemini-entrypoint.sh"]
