{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true
  },
  "include": ["src/**/*", "config/**/*", "scripts/**/*", "knexfile.ts", "packages/dashboard/**/*", "packages/core/**/*"],
  "exclude": ["node_modules", "dist", "test/**/*", "packages/dashboard/node_modules", "packages/dashboard/dist", "packages/core/node_modules", "packages/core/dist"]
}
