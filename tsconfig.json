{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@propr/core": ["packages/core/src/index.ts"],
      "@propr/shared": ["packages/shared/src/index.ts"]
    }
  },
  "include": ["src/**/*", "config/**/*", "scripts/**/*", "knexfile.ts", "packages/api/**/*", "packages/core/**/*", "packages/shared/**/*"],
  "exclude": ["node_modules", "dist", "test/**/*", "packages/api/node_modules", "packages/api/dist", "packages/core/node_modules", "packages/core/dist"]
}
