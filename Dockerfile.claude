# Claude Code agent image. Extends propr/agent-base (alpine + common tooling).
# The CLI is installed at build time and exercised with --version as a smoke
# test so binary-loading regressions fail the build rather than leaking into
# user runtime.

# BASE_TAG must match the exact version of propr/agent-base built alongside
# this agent image. scripts/build-images.sh passes it automatically; a direct
# `docker build` must pass --build-arg BASE_TAG=<version>.
ARG BASE_TAG
FROM propr/agent-base:${BASE_TAG}

ARG CLI_VERSION=latest

USER root
RUN npm install -g @anthropic-ai/claude-code@${CLI_VERSION}
# Smoke test: forces the binary to load shared libraries and exec.
RUN claude --version
USER node

RUN git config --global user.name "ProPR Claude Bot" \
    && git config --global user.email "claude-bot@propr.dev" \
    && git config --global init.defaultBranch main \
    && git config --global --add safe.directory '*'

COPY --chown=node:node scripts/claude-entrypoint.sh /home/node/claude-entrypoint.sh
USER root
RUN chmod +x /home/node/claude-entrypoint.sh
USER node

ENTRYPOINT ["/home/node/claude-entrypoint.sh"]
