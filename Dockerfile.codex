# OpenAI Codex agent image. Extends the ProPR agent base image (Debian/glibc + common tooling).
# The CLI is installed at build time and exercised with --version as a smoke
# test so binary-loading regressions fail the build rather than leaking into
# user runtime.

# BASE_IMAGE must point at the exact agent-base image built alongside this
# agent image. scripts/build-images.sh passes it automatically.
ARG BASE_IMAGE=propr/agent-base:latest
FROM ${BASE_IMAGE}

ARG CLI_VERSION=latest

USER root
# ripgrep (rg): Codex's agent instructions prefer `rg` for repository search
# because it is substantially faster and more predictable than recursive
# grep/find fallbacks. Installing it explicitly here makes the runtime contract
# reliable instead of depending on whatever happens to be in the shared base
# image. Do NOT remove this as an "unused" package — it is invoked by the Codex
# agent at runtime, so its absence only surfaces as a degraded "rg is not
# installed here" message rather than a build failure.
RUN apt-get update \
    && apt-get install -y --no-install-recommends ripgrep \
    && rm -rf /var/lib/apt/lists/*
# Smoke test: fail the build now if rg ever disappears from the image.
RUN rg --version
RUN npm install -g @openai/codex@${CLI_VERSION}
# Smoke test: forces the Rust binary bundled with the CLI to load and exec.
RUN codex --version
USER node

RUN git config --global user.name "ProPR Codex Bot" \
    && git config --global user.email "codex-bot@propr.dev" \
    && git config --global init.defaultBranch main \
    && git config --global --add safe.directory '*'

COPY --chown=node:node scripts/codex-entrypoint.sh /home/node/codex-entrypoint.sh
USER root
RUN chmod +x /home/node/codex-entrypoint.sh
USER node

ENTRYPOINT ["/home/node/codex-entrypoint.sh"]
