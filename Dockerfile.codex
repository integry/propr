# Dockerfile for OpenAI Codex CLI execution environment
# Based on the pattern used for Claude and Gemini agents

FROM node:20-slim

# Install required system dependencies
# procps is needed for Codex process management
# iptables is used for network sandboxing if needed
RUN apt-get update && apt-get install -y \
    git \
    curl \
    ca-certificates \
    iptables \
    ripgrep \
    sudo \
    procps \
    && rm -rf /var/lib/apt/lists/*

# Install GitHub CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update \
    && apt-get install gh -y \
    && rm -rf /var/lib/apt/lists/*

# Use the existing node user (UID 1000) and give it sudo privileges
# This is required for the entrypoint script to fix permissions before dropping privileges
RUN echo "node ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

# CLI version argument - can be overridden at build time
ARG CLI_VERSION=0.120.0

# Install OpenAI Codex CLI globally
RUN npm install -g @openai/codex@${CLI_VERSION}

# Increase Node.js memory limit for large prompts/responses
ENV NODE_OPTIONS="--max-old-space-size=8192"

# Create workspace directory only - Codex config will be mounted at runtime
RUN mkdir -p /home/node/workspace && \
    chown -R node:node /home/node

# Copy firewall initialization script (reused from existing scripts)
COPY scripts/init-firewall.sh /usr/local/bin/init-firewall.sh
RUN chmod +x /usr/local/bin/init-firewall.sh

# Switch to non-root user
USER node
WORKDIR /home/node/workspace

# Set up Git configuration for the container user
RUN git config --global user.name "Codex Bot" && \
    git config --global user.email "codex-bot@openai.com" && \
    git config --global init.defaultBranch main && \
    git config --global --add safe.directory '*'

# Copy gh wrapper script
COPY --chown=node:node scripts/gh-wrapper.sh /usr/local/bin/gh-wrapper
RUN chmod +x /usr/local/bin/gh-wrapper

# Create entrypoint script
COPY --chown=node:node scripts/codex-entrypoint.sh /home/node/codex-entrypoint.sh
RUN chmod +x /home/node/codex-entrypoint.sh

# Set default entrypoint
ENTRYPOINT ["/home/node/codex-entrypoint.sh"]
