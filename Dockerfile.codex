# OpenAI Codex agent image. Extends propr/agent-base (alpine + common tooling).
# The CLI is installed at build time and exercised with --version as a smoke
# test so binary-loading regressions fail the build rather than leaking into
# user runtime.

# BASE_TAG must match the exact version of propr/agent-base built alongside
# this agent image. scripts/build-images.sh passes it automatically; a direct
# `docker build` must pass --build-arg BASE_TAG=<version>.
ARG BASE_TAG
FROM propr/agent-base:${BASE_TAG}

ARG CLI_VERSION=latest

USER root
RUN npm install -g @openai/codex@${CLI_VERSION}
# Smoke test: forces the Rust binary bundled with the CLI to load and exec.
RUN codex --version
USER node

RUN git config --global user.name "ProPR Codex Bot" \
    && git config --global user.email "codex-bot@propr.dev" \
    && git config --global init.defaultBranch main \
    && git config --global --add safe.directory '*'

COPY --chown=node:node scripts/codex-entrypoint.sh /home/node/codex-entrypoint.sh
USER root
RUN chmod +x /home/node/codex-entrypoint.sh
USER node

ENTRYPOINT ["/home/node/codex-entrypoint.sh"]
