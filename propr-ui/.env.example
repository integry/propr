# Runtime configuration (preferred)
# ----------------------------------
# The hosted UI is a single static bundle that serves many local stacks, so the
# API / Socket.IO base URL is configured at container start, not at build time.
# Set this to the per-instance proxy URL; the entrypoint writes it into the
# served config.js and the browser reads it from window.__PROPR_CONFIG__.
# Used for both REST and Socket.IO. Leave empty for same-origin deployments.
PROPR_UI_PUBLIC_API_URL=https://your-instance.proxy.propr.dev

# Build-time configuration (optional)
# -----------------------------------
# Bakes a default API base URL into a static single-target build. Runtime config
# (PROPR_UI_PUBLIC_API_URL) takes precedence when present. Leave unset for the
# hosted UI; runtime config supplies the per-instance proxy URL instead.
# VITE_API_BASE_URL=https://app.propr.dev

# Vite proxy target for local development (used in vite.config.ts).
# Local dev keeps an empty base URL and proxies /api and /socket.io to here.
VITE_API_URL=http://localhost:4000

# Demo mode is controlled by the backend with PROPR_DEMO_MODE=true.
# The frontend discovers it at runtime from /api/auth/demo-mode.
