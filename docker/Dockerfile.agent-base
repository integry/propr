# Shared base for propr/agent-* images.
#
# Contains everything common to Claude / Codex / Antigravity / OpenCode / Vibe
# agent containers: system tools, GitHub CLI, firewall script, gh wrapper,
# third-party notices. Each concrete agent image extends this with its own CLI
# install and entrypoint.
#
# Debian slim provides glibc compatibility for common user-installed tooling,
# prebuilt binaries, native npm addons, Python wheels, and release-binary CLIs.
#
# Build:
#   docker build -f docker/Dockerfile.agent-base -t propr/agent-base .

FROM node:20-bookworm-slim

ARG BASH_VERSION=5.2.15-2+b13
ARG BUILD_ESSENTIAL_VERSION=12.9
ARG CA_CERTIFICATES_VERSION=20230311+deb12u1
ARG CURL_VERSION=7.88.1-10+deb12u15
ARG GH_VERSION=2.96.0
ARG GIT_VERSION=1:2.39.5-0+deb12u3
ARG IPTABLES_VERSION=1.8.9-2
ARG PROCPS_VERSION=2:4.0.2-3
ARG SUDO_VERSION=1.9.13p3-1+deb12u4
ARG TINI_VERSION=0.19.0-1+b3
ARG GITHUBCLI_KEYRING_SHA256=6084d5d7bd8e288441e0e94fc6275570895da18e6751f70f057485dc2d1a811b

# System dependencies:
#   GNU coreutils/env is provided by the Debian base as an Essential package.
#   git, curl, ca-certificates — source + network
#   sudo                        — entrypoints fix ownership before dropping privs
#   iptables                    — optional firewall init
#   procps                      — ps/top used by some CLI internals
#   build-essential             — native addon/tool compilation
#   gh                          — GitHub CLI command from cli.github.com apt repo
#   tini                        — PID 1 for clean signal handling
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates="${CA_CERTIFICATES_VERSION}" \
        curl="${CURL_VERSION}" \
    && mkdir -p -m 755 /etc/apt/keyrings \
    && curl -fsSL -o /etc/apt/keyrings/githubcli-archive-keyring.gpg https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    && echo "${GITHUBCLI_KEYRING_SHA256}  /etc/apt/keyrings/githubcli-archive-keyring.gpg" | sha256sum -c - \
    && chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        bash="${BASH_VERSION}" \
        build-essential="${BUILD_ESSENTIAL_VERSION}" \
        gh="${GH_VERSION}" \
        git="${GIT_VERSION}" \
        iptables="${IPTABLES_VERSION}" \
        procps="${PROCPS_VERSION}" \
        sudo="${SUDO_VERSION}" \
        tini="${TINI_VERSION}" \
    && rm -rf /var/lib/apt/lists/*

# node:20-bookworm-slim already has a `node` user (UID 1000). Grant it passwordless sudo
# for the entrypoint scripts that need to adjust file ownership before dropping privs.
RUN echo "node ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

# Workspace that agents check out code into.
RUN mkdir -p /home/node/workspace && chown -R node:node /home/node

# Shared helper scripts.
COPY scripts/init-firewall.sh /usr/local/bin/init-firewall.sh
COPY scripts/gh-wrapper.sh /usr/local/bin/gh-wrapper
RUN chmod +x /usr/local/bin/init-firewall.sh /usr/local/bin/gh-wrapper

# Third-party notices (required by bundled Apache-2.0 and proprietary components).
COPY NOTICE /usr/share/licenses/propr/NOTICE
COPY THIRD_PARTY_LICENSES.md /usr/share/licenses/propr/THIRD_PARTY_LICENSES.md

# Roomy heap for large prompts/responses.
ENV NODE_OPTIONS="--max-old-space-size=8192"

USER node
WORKDIR /home/node/workspace

ENTRYPOINT ["/usr/bin/tini", "--"]
