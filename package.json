{
  "name": "gitfix",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "test": "node --test",
    "start": "node dist/src/index.js",
    "dev": "tsx watch src/index.js",
    "daemon": "node dist/src/daemon.js",
    "daemon:dev": "LOG_LEVEL=debug tsx src/daemon.js",
    "daemon:reset": "node dist/src/daemon.js --reset",
    "daemon:reset:dev": "LOG_LEVEL=debug tsx src/daemon.js --reset",
    "worker": "node dist/src/worker.js",
    "worker:dev": "LOG_LEVEL=debug tsx src/worker.js",
    "worker:reset": "node dist/src/worker.js --reset",
    "worker:reset:dev": "LOG_LEVEL=debug tsx src/worker.js --reset",
    "analysis-worker": "node dist/src/analysis_worker.js",
    "analysis-worker:dev": "LOG_LEVEL=debug tsx src/analysis_worker.js",
    "config:repos": "tsx scripts/list-repo-configs.js",
    "db:migrate": "npx knex migrate:latest --knexfile ./knexfile.ts",
    "compose:up": "./scripts/compose.sh up",
    "compose:dev": "./scripts/compose.sh dev",
    "compose:down": "./scripts/compose.sh down",
    "compose:logs": "./scripts/compose.sh logs",
    "compose:build": "./scripts/compose.sh build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Automated GitHub Issue Processor with AI-powered solution generation",
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.0.1",
    "@octokit/auth-app": "^8.0.1",
    "@octokit/core": "^7.0.2",
    "@octokit/plugin-paginate-rest": "^13.1.1",
    "bullmq": "^5.53.0",
    "dotenv": "^16.5.0",
    "execa": "^9.5.2",
    "fs-extra": "^11.3.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.13.1",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "simple-git": "^3.27.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@octokit/webhooks-types": "^7.6.1",
    "@types/fs-extra": "^11.0.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.39.1",
    "globals": "^16.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1"
  }
}
