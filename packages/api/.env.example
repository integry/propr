# Dashboard API Configuration
DASHBOARD_API_PORT=4000

# Frontend URL (for OAuth callbacks and CORS)
# Required in normal and demo mode for auth redirects.
FRONTEND_URL=http://localhost:5173
# Optional comma-separated redirect hosts for auth preview flows. FRONTEND_URL and
# COOKIE_DOMAIN are always allowed.
# AUTH_REDIRECT_ALLOWED_HOSTS=preview.example.com

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Authentication
SESSION_SECRET=your-secret-key-here-change-in-production

# Demo Mode
# Set to 'true' to allow read-only access without GitHub OAuth and block all mutating API requests.
# Public demo deployments should use a curated config/database. Only repositories marked
# demoVisible=true in repos_to_monitor or listed in PROPR_DEMO_REPOSITORIES are visible.
# Drafts are visible only for PROPR_DEMO_VISIBLE_USER_IDS, which defaults to the synthetic
# demo user id "demo".
PROPR_DEMO_MODE=false
# PROPR_DEMO_REPOSITORIES=owner/repo
# PROPR_DEMO_VISIBLE_USER_IDS=demo

# GitHub OAuth (same as main app)
GH_OAUTH_CLIENT_ID=your-github-oauth-client-id
GH_OAUTH_CLIENT_SECRET=your-github-oauth-client-secret
GH_OAUTH_CALLBACK_URL=http://localhost:4000/api/auth/github/callback

# Claude API (same as main app)
ANTHROPIC_API_KEY=your-anthropic-api-key
